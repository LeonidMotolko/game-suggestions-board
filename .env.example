# Database
POSTGRES_USER=game_suggestions_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=game_suggestions
DATABASE_URL=postgresql+asyncpg://game_suggestions_user:change_me_strong_password@db:5432/game_suggestions

# FastAPI
SECRET_KEY=change-me-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email (SMTP) - for development, console output can be used
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@example.com
EMAIL_VERIFICATION_REQUIRED=False  # set True in production

# File storage
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
